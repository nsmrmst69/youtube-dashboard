# .env.example — このファイルをコピーして .env を作成してください
# .env は Git に含まれません（.gitignore で除外済み）

# Google SpreadsheetのID（URLの /d/～/edit の間の文字列）
SPREADSHEET_ID=your_spreadsheet_id_here

# スプレッドシートのシート名（タブ名）
SHEET_NAME=運営スケジュール

# Google サービスアカウントの認証情報（推奨）
# credentials.json の中身を1行のJSONに変換して貼り付ける
# 変換コマンド: cat credentials.json | python3 -c "import sys,json; print(json.dumps(json.load(sys.stdin)))"
# GOOGLE_CREDENTIALS={"type":"service_account","project_id":"..."}

# 上記の代わりにファイルパスで指定することも可能（後方互換）
# CREDENTIALS_PATH=credentials.json

# Googleドライブのアップロード先フォルダID（省略時はアップロードしない）
# フォルダIDはドライブのURLの末尾: https://drive.google.com/drive/folders/【ここ】
# DRIVE_FOLDER_ID=your_folder_id_here

# ── AI Next Actions 設定（Gemini API） ────────────────────────
# Gemini API キー（省略時はNext Actions生成をスキップ）
# 取得: https://aistudio.google.com/app/apikey（無料枠あり）
# GEMINI_API_KEY=your_gemini_api_key_here

# ── Chatwork 設定（日報自動送信） ──────────────────────────────

# Chatwork APIトークン（省略時はChatwork送信をスキップ）
# 取得: https://www.chatwork.com/service/packages/chatwork/subpackages/api/token.php
# CHATWORK_API_TOKEN=your_api_token_here

# 送信先ルームIDをカンマ区切りで指定
# ルームIDはChatworkのURL: https://www.chatwork.com/#!rid【ここ】
# 例) クライアント用チャンネルと自分用チャンネルの両方に送る場合:
# CHATWORK_ROOM_IDS=123456789,987654321
