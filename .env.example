# .env.example — このファイルをコピーして .env を作成してください
# .env は Git に含まれません（.gitignore で除外済み）

# Google SpreadsheetのID（URLの /d/～/edit の間の文字列）
SPREADSHEET_ID=your_spreadsheet_id_here

# スプレッドシートのシート名（タブ名）
SHEET_NAME=スケジュール

# Google サービスアカウントの認証情報（推奨）
# credentials.json の中身を1行のJSONに変換して貼り付ける
# 変換コマンド: cat credentials.json | python3 -c "import sys,json; print(json.dumps(json.load(sys.stdin)))"
# GOOGLE_CREDENTIALS={"type":"service_account","project_id":"..."}

# 上記の代わりにファイルパスで指定することも可能（後方互換）
# CREDENTIALS_PATH=credentials.json

# Googleドライブのアップロード先フォルダID（省略時はアップロードしない）
# フォルダIDはドライブのURLの末尾: https://drive.google.com/drive/folders/【ここ】
# DRIVE_FOLDER_ID=your_folder_id_here
